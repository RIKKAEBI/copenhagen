{
  "name": "copenhagen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "db:migrate:local": "wrangler d1 migrations apply copenhagen --local",
    "db:migrate": "wrangler d1 migrations apply copenhagen --remote",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "wrangler": "4.105.0"
  }
}
